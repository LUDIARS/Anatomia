+  isSessionPaused(db: Database.Database, sessionId: string): boolean {
+    const row = db.prepare(`SELECT paused FROM sessions WHERE id = ?`).get(sessionId) as
+      | { paused: number }
+      | undefined;
+    return row?.paused === 1;
+  }
+
+  /** セッション一時停止フラグの設定. */
+  setSessionPaused(db: Database.Database, sessionId: string, paused: boolean): void {
+    db.prepare(`UPDATE sessions SET paused = ? WHERE id = ?`).run(paused ? 1 : 0, sessionId);
+  }
