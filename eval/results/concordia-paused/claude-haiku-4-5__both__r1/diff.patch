+      });
+      await app.request("/v1/sessions/serialize-test/paused/toggle", { method: "POST" });
+      const r = await app.request("/v1/sessions/serialize-test");
+      const j = (await r.json()) as { session: { paused: boolean } };
+      expect(j.session.paused).toBe(true);
+    });
+
+    it("404 for unknown session", async () => {
+      const r = await app.request("/v1/sessions/unknown/paused");
+      expect(r.status).toBe(404);
+    });
+  });
 });
