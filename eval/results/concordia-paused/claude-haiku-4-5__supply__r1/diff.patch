+  it("patchSession can toggle paused flag", () => {
+    repo.insertSession({
+      id: "a", provider: "claude-code", repo_path: "/x", repo_origin: null,
+      branch: null, host: "h", started_at: 1, last_seen_at: 1,
+      transcript_path: null, metadata: null,
+    });
+    const s1 = repo.findSession("a");
+    expect(s1?.paused).toBe(0);
+    repo.patchSession("a", { paused: 1 });
+    const s2 = repo.findSession("a");
+    expect(s2?.paused).toBe(1);
+    repo.patchSession("a", { paused: 0 });
+    const s3 = repo.findSession("a");
+    expect(s3?.paused).toBe(0);
+  });
 });
