@@ -0,0 +1,136 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import { makeTestDb } from "./helpers/db.js";
+import { ProposalRateLimiter } from "../src/admin/proposal-ratelimit.js";
+import { AdminState } from "../src/admin/state.js";
+import { SessionsRepo } from "../src/db/sessions-repo.js";
+import { TasksRepo } from "../src/db/tasks-repo.js";
+import { ChatRepo } from "../src/db/chat-repo.js";
+import { Dispatcher } from "../src/dispatcher.js";
+import type Database from "better-sqlite3";
+
+/** 昼帯固定 (深夜帯抑制を避ける)。 */
+const DAYTIME = () => new Date(2026, 4, 22, 14, 0, 0);
+
+describe("ProposalRateLimiter", () => {
+  let db: Database.Database;
+  let clock: number;
+  beforeEach(() => {
+    db = makeTestDb();
+    clock = 1000;
+  });
+
+  function limiter(cfg: { window_sec: number; max: number }) {
+    return new ProposalRateLimiter({ db, getConfig: () => cfg, now: () => clock });
+  }
+
+  it("窓内で上限に達するとスキップし、 窓が明けると再開する", () => {
+    const rl = limiter({ window_sec: 60, max: 2 });
+    expect(rl.tryConsume("a")).toBe(true); // 1
+    expect(rl.tryConsume("a")).toBe(true); // 2
+    expect(rl.tryConsume("a")).toBe(false); // 上限到達 → skip
+    expect(rl.tryConsume("a")).toBe(false); // 窓内は据え置きで skip 継続
+
+    // 窓未明け (start=1000, window=60 → 1060 で明ける)。
+    clock = 1059;
+    expect(rl.tryConsume("a")).toBe(false);
+
+    // 窓明け → カウントリセットで再開。
+    clock = 1060;
+    expect(rl.tryConsume("a")).toBe(true); // reset 後 1 回目
+    expect(rl.tryConsume("a")).toBe(true); // 2 回目
+    expect(rl.tryConsume("a")).toBe(false); // 再び上限
+  });
+
+  it("session ごとに独立してカウントする", () => {
+    const rl = limiter({ window_sec: 60, max: 1 });
+    expect(rl.tryConsume("a")).toBe(true);
+    expect(rl.tryConsume("a")).toBe(false);
+    // 別 session は影響を受けない。
+    expect(rl.tryConsume("b")).toBe(true);
+    expect(rl.tryConsume("b")).toBe(false);
+  });
+
+  it("max = 0 はレートリミット無効 (常に許可)", () => {
+    const rl = limiter({ window_sec: 60, max: 0 });
+    for (let i = 0; i < 10; i++) expect(rl.tryConsume("a")).toBe(true);
+  });
+
+  it("カウンタ状態が schema_meta に永続化され、 再生成しても引き継がれる", () => {
+    const first = limiter({ window_sec: 60, max: 2 });
+    expect(first.tryConsume("a")).toBe(true);
+    expect(first.tryConsume("a")).toBe(true);
+    // 同じ db を使う別インスタンスでも窓内カウントは引き継がれる。
+    const second = new ProposalRateLimiter({ db, getConfig: () => ({ window_sec: 60, max: 2 }), now: () => clock });
+    expect(second.tryConsume("a")).toBe(false);
+  });
+
+  it("AdminState の解決 (グローバル + session 上書き) と連動する", () => {
+    const admin = new AdminState(db);
+    admin.setProposalRateLimit({ window_sec: 60, max: 1 });
+    admin.setProposalRateLimitOverride("vip", { window_sec: 60, max: 3 });
+    const rl = new ProposalRateLimiter({
+      db,
+      getConfig: (sid) => admin.resolveProposalRateLimit(sid),
+      now: () => clock,
+    });
+    // グローバル既定 (max=1)。
+    expect(rl.tryConsume("plain")).toBe(true);
+    expect(rl.tryConsume("plain")).toBe(false);
+    // 上書き session (max=3)。
+    expect(rl.tryConsume("vip")).toBe(true);
+    expect(rl.tryConsume("vip")).toBe(true);
+    expect(rl.tryConsume("vip")).toBe(true);
+    expect(rl.tryConsume("vip")).toBe(false);
+  });
+});
+
+describe("Dispatcher × proposal rate limit", () => {
+  function fresh() {
+    const db = makeTestDb();
+    return { db, sessions: new SessionsRepo(db), tasks: new TasksRepo(db), chat: new ChatRepo(db) };
+  }
+  function startSession(repo: SessionsRepo, id: string) {
+    repo.insertSession({
+      id, provider: "claude-code", repo_path: "/x", repo_origin: "origin", branch: "main",
+      host: "h", started_at: 1, last_seen_at: 1, transcript_path: null, metadata: null,
+    });
+  }
+
+  it("上限到達中は review-summary 提案を enqueue せず、 窓が明けたら再開する", () => {
+    const env = fresh();
+    startSession(env.sessions, "a");
+    let clock = 1000;
+    const limiter = new ProposalRateLimiter({
+      db: env.db,
+      getConfig: () => ({ window_sec: 60, max: 1 }),
+      now: () => clock,
+    });
+    const d = new Dispatcher({
+      ...env,
+      rng: () => 0.99, // 確率発火 (chitchat) は起こさず、 決定的な review-summary だけを使う
+      now: DAYTIME,
+      tryConsumeProposal: (sid) => limiter.tryConsume(sid),
+    });
+
+    // 5 件の work event → workCount % 5 == 0 で review-summary が決定的に発火。
+    const appendWork = (base: number) => {
+      for (let i = 0; i < 5; i++) {
+        env.sessions.appendEvent({ session_id: "a", ts: base + i, kind: "edit", payload: { file: "src/foo.ts" } });
+      }
+    };
+
+    appendWork(0);
+    d.onEventAppended(env.sessions.findSession("a")!, 5);
+    expect(env.tasks.pull("a").some((t) => t.kind === "review-summary")).toBe(true); // 1 件目: 許可
+
+    appendWork(10);
+    d.onEventAppended(env.sessions.findSession("a")!, 10);
+    expect(env.tasks.pull("a").some((t) => t.kind === "review-summary")).toBe(false); // 上限到達: skip
+
+    // 窓明け → 再開。
+    clock = 1100;
+    appendWork(20);
+    d.onEventAppended(env.sessions.findSession("a")!, 15);
+    expect(env.tasks.pull("a").some((t) => t.kind === "review-summary")).toBe(true); // 再び許可
+  });
+});
