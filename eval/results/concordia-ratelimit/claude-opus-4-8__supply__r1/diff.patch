+function assertRateLimit(value: ProposalRateLimit): ProposalRateLimit {
+  if (!Number.isFinite(value?.window_sec) || !Number.isFinite(value?.max_count)) {
+    throw new Error("proposal rate limit window_sec / max_count must be finite numbers");
+  }
+  return {
+    window_sec: clamp(Math.floor(value.window_sec), PROPOSAL_RATE_WINDOW_MIN, PROPOSAL_RATE_WINDOW_MAX),
+    max_count: clamp(Math.floor(value.max_count), PROPOSAL_RATE_COUNT_MIN, PROPOSAL_RATE_COUNT_MAX),
