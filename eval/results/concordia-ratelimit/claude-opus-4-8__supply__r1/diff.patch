+function sanitizeRateLimit(input: unknown, fallback: ProposalRateLimit): ProposalRateLimit {
+  const obj = (input && typeof input === "object") ? (input as Record<string, unknown>) : {};
+  const ws = Number(obj.window_sec);
+  const mc = Number(obj.max_count);
+  return {
+    window_sec: Number.isFinite(ws)
+      ? clamp(Math.floor(ws), PROPOSAL_RATE_WINDOW_MIN, PROPOSAL_RATE_WINDOW_MAX)
+      : fallback.window_sec,
+    max_count: Number.isFinite(mc)
+      ? clamp(Math.floor(mc), PROPOSAL_RATE_COUNT_MIN, PROPOSAL_RATE_COUNT_MAX)
+      : fallback.max_count,
+  };
+}
