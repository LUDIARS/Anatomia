+import { describe, it, expect, beforeEach } from "vitest";
+import { makeTestDb } from "./helpers/db.js";
+import { AdminState } from "../src/admin/state.js";
+import {
+  evaluateProposalRate,
+  ProposalRateLimiter,
+} from "../src/admin/proposal-rate-limit.js";
+
+describe("evaluateProposalRate (pure)", () => {
+  it("窓内で上限に達したら skip、 窓が明けたら count リセットで再開", () => {
+    const cfg = { window_sec: 60, max_count: 2 };
+    // 窓開始 t=1000。 1 回目 / 2 回目は allow、 count が積み上がる。
+    let r = evaluateProposalRate(cfg, undefined, 1000);
+    expect(r.allowed).toBe(true);
+    expect(r.state).toEqual({ window_start_sec: 1000, count: 1 });
+
+    r = evaluateProposalRate(cfg, r.state, 1010);
+    expect(r.allowed).toBe(true);
+    expect(r.state).toEqual({ window_start_sec: 1000, count: 2 });
+
+    // 3 回目: 同窓内で上限到達 → skip。 count は増えない。
+    r = evaluateProposalRate(cfg, r.state, 1020);
+    expect(r.allowed).toBe(false);
+    expect(r.reason).toMatch(/rate limit reached/);
+    expect(r.state).toEqual({ window_start_sec: 1000, count: 2 });
+
+    // 窓が明ける (1000 + 60 = 1060 以降) → リセットして再開。
+    r = evaluateProposalRate(cfg, r.state, 1061);
+    expect(r.allowed).toBe(true);
+    expect(r.state).toEqual({ window_start_sec: 1061, count: 1 });
+  });
+
+  it("max_count <= 0 は無制限 (常に allow、 state 据え置き)", () => {
+    const cfg = { window_sec: 60, max_count: 0 };
+    const prev = { window_start_sec: 500, count: 99 };
+    const r = evaluateProposalRate(cfg, prev, 10_000);
+    expect(r.allowed).toBe(true);
+    expect(r.state).toBe(prev); // 触らない
+  });
+});
+
+describe("ProposalRateLimiter (AdminState 永続化 + fake clock)", () => {
+  let env: { db: ReturnType<typeof makeTestDb>; admin: AdminState };
+  beforeEach(() => {
+    const db = makeTestDb();
+    env = { db, admin: new AdminState(db) };
+  });
+
+  it("上限到達でスキップ → 窓明けで再開 (カウンタ状態は schema_meta に永続)", () => {
+    env.admin.setProposalRateDefault(60, 2);
+    let now = 1000;
+    const limiter = new ProposalRateLimiter(env.admin, () => now);
+
+    expect(limiter.check("sess").allowed).toBe(true);  // 1/2
+    now = 1010;
+    expect(limiter.check("sess").allowed).toBe(true);  // 2/2
+    now = 1020;
+    const v = limiter.check("sess");                   // 上限到達 → skip
+    expect(v.allowed).toBe(false);
+    expect(v.reason).toMatch(/rate limit/);
+
+    // カウンタ状態は永続化されている (別インスタンスから読める)。
+    expect(new AdminState(env.db).getProposalRateStateFor("sess")).toEqual({
+      window_start_sec: 1000,
+      count: 2,
+    });
+
+    // 窓が明けたら再開。
+    now = 1061;
+    expect(limiter.check("sess").allowed).toBe(true);  // リセット後 1/2
+  });
+
+  it("session 個別 override が既定より優先される", () => {
+    env.admin.setProposalRateDefault(60, 5);
+    env.admin.setProposalRateOverride("strict", 60, 1); // この session だけ厳しく
+    let now = 2000;
+    const limiter = new ProposalRateLimiter(env.admin, () => now);
+
+    expect(limiter.check("strict").allowed).toBe(true);   // 1/1
+    now = 2005;
+    expect(limiter.check("strict").allowed).toBe(false);  // override 上限 1 で skip
+
+    // 別 session は既定 (5 回) なので通る。
+    expect(limiter.check("loose").allowed).toBe(true);
+  });
+});
