+/** schema_meta の JSON から {window_sec, max_count} を復元 (壊れた / 不正値は null)。 */
+function parseRateConfig(raw: string | null): ProposalRateConfig | null {
+  if (!raw) return null;
+  try {
+    const parsed = JSON.parse(raw) as unknown;
+    if (parsed && typeof parsed === "object") {
+      const o = parsed as Record<string, unknown>;
+      const w = Number(o.window_sec);
+      const m = Number(o.max_count);
+      if (Number.isFinite(w) && Number.isFinite(m)) {
+        return normalizeRateConfig(w, m);
+      }
+    }
+  } catch {
+    // 壊れた値は無視。
+  }
+  return null;
+}
+
+/** window / max_count を許容範囲に丸めた config に正規化 (pure)。 */
+function normalizeRateConfig(windowSec: number, maxCount: number): ProposalRateConfig {
+  const w = Number.isFinite(windowSec) ? Math.floor(windowSec) : DEFAULT_PROPOSAL_WINDOW_SEC;
+  const m = Number.isFinite(maxCount) ? Math.floor(maxCount) : DEFAULT_PROPOSAL_MAX_COUNT;
+  return {
+    window_sec: clamp(w, PROPOSAL_WINDOW_MIN, PROPOSAL_WINDOW_MAX),
+    max_count: clamp(m, PROPOSAL_MAX_COUNT_MIN, PROPOSAL_MAX_COUNT_MAX),
+  };
+}
